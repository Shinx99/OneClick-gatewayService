# ===== Gateway =====
APP_NAME=gateway-service
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

SPRING_CLOUD_COMPATIBILITY_VERIFIER_ENABLED=false

# ===== WebConfig =====
# ====== Config CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8081


# Frontend URL (CORS)
APP_FRONTEND_URL=http://localhost:3000

# Redis (shared authservice)
SPRING_REDIS_HOST=gateway-redis
SPRING_REDIS_PORT=6379

# Rate Limits - DEV (không block Swagger)
GATEWAY_AUTH_REPLENISH_RATE=1000      # req/giây auth (register/login)
GATEWAY_AUTH_BURST_CAPACITY=1000      # Burst 16 phút
GATEWAY_CV_REPLENISH_RATE=500         # CV/job nhiều request
GATEWAY_CV_BURST_CAPACITY=2000
GATEWAY_SOCIAL_REPLENISH_RATE=200     # Social ít quan trọng hơn
GATEWAY_SOCIAL_BURST_CAPACITY=1000

# Eureka (nếu dùng)
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8761/eureka/

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_CLOUD_GATEWAY=DEBUG
